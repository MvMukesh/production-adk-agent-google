# ADK API Server
ADK_API_BASE=http://localhost:8000
ADK_API_HOST=0.0.0.0
ADK_API_PORT=8000
ADK_AGENTS_DIR=agents
ADK_DB_URL=sqlite:///./data/sessions.db

# Default agent & user
ADK_APP_NAME=simple
ADK_USER_ID=demo_user

# Model & API keys (required)
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
AGENT_MODEL=gemini-2.0-flash

# Tavily MCP (requires Node.js + npx)
TAVILY_MCP_COMMAND=npx
TAVILY_MCP_ARGS=-y,tavily-mcp

# Next.js frontend
NEXT_HOST=0.0.0.0
NEXT_PORT=3000

# HTTP timeouts (seconds)
HTTP_TIMEOUT_SECONDS=60
HTTP_RUN_TIMEOUT_SECONDS=120

# GCP / Cloud Run
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=False
CLOUD_RUN_SERVICE_NAME=adk-agent-service
CLOUD_RUN_AGENT_PATH=agents/simple
